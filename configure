if [ -z "$PBOS_ARCH" ]; then
	echo "PBOS_ARCH not set"
	exit 1
fi

if [ -z "$PBOS_TRIPLET" ]; then
	echo "PBOS_TRIPLET not set"
	exit 1
fi

echo "CC=$CC"
echo "CXX=$CXX"
echo "ASM=$ASM"
echo "LD=$LD"
echo "PBOS_ARCH=$PBOS_ARCH"
echo "PBOS_TRIPLET=$PBOS_TRIPLET"

for ((i=1; i<=$#; i++)); do
    case ${!i} in
        "--clean-previous")
            echo "Removing previous build directory..."
            rm -rf build/
        ;;
        *)
            echo "Error: unresolved argument '${!i}'"
            exit 1;
    esac
done

cmake \
--no-warn-unused-cli \
-DCMAKE_BUILD_TYPE:STRING=Debug \
--toolchain ./cmake/Platform/$PBOS_TRIPLET-pbkim.cmake \
-DCMAKE_EXPORT_COMPILE_COMMANDS:BOOL=TRUE \
-G "Ninja" \
-S . -B build
